{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(curl *)",
      "Bash(export PATH=*)",
      "Bash(export PATH=\"$PATH:/c/Program Files/GitHub CLI\")"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const cmd=process.env.CLAUDE_TOOL_INPUT||''; if(cmd.includes('node_modules')||cmd.includes('npm install')&&cmd.includes('--save-dev')){process.exit(2)}\""
          }
        ]
      }
    ]
  }
}
